<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude Lombok-generated code -->
    <Match>
        <Class name="~.*\$\$.*"/>
    </Match>
    <!-- Exclude test classes -->
    <Match>
        <Class name="~.*Test"/>
    </Match>
    <Match>
        <Package name="~.*\.test\..*"/>
    </Match>
    <!-- Suppress EI_EXPOSE_REP on Spring beans / @ConfigurationProperties (Lombok constructors) -->
    <Match>
        <Bug code="EI, EI2"/>
    </Match>
</FindBugsFilter>
