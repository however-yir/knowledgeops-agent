<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude Lombok-generated code -->
    <Match>
        <Class name="~.*\$\$.*"/>
    </Match>
    <!-- Exclude test classes -->
    <Match>
        <Class name="~.*Test"/>
    </Match>
    <Match>
        <Package name="~.*\.test\..*"/>
    </Match>
</FindBugsFilter>
